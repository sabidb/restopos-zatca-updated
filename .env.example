# Firebase web config — NOT secret (it identifies the project; real protection is
# Firestore rules + Cloud Functions). Copy to .env and fill in from the Firebase
# console → Project settings → Your apps.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=restopos-db.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=restopos-db
VITE_FIREBASE_STORAGE_BUCKET=restopos-db.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Cloud Function SECRETS are NOT set here — they live in Google Secret Manager:
#   firebase functions:secrets:set QZ_PRIVATE_KEY
#   firebase functions:secrets:set EMAILJS_PRIVATE_KEY
#   firebase functions:secrets:set AI_API_KEY   # optional (else config/ai is used)
